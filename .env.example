# ---------------------------------------------------------------------------
# DNSentinel backend configuration.
# Copy this file to `backend/.env` (or export the vars in your shell / host)
# and fill in the values you need. Everything here has a safe default, so the
# app boots with an empty .env — the intel providers just stay disabled.
# ---------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins. Use "*" for local dev; in
# production set this to your deployed frontend URL, e.g.
#   CORS_ORIGINS=https://dnsentinel.vercel.app
CORS_ORIGINS=*

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to True to enable verbose/debug behaviour.
DEBUG=False

# Maximum accepted DNS query length (RFC 1035 caps FQDNs at 253 chars).
MAX_QUERY_LENGTH=253

# --- Threat-intelligence providers (all optional) --------------------------
# Features that use these degrade gracefully when the key is absent.
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
GROQ_API_KEY=

# --- Redis (optional, used for shared state / caching) ---------------------
REDIS_HOST=localhost
REDIS_PORT=6379
